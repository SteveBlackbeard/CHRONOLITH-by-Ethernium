{
  "version": "1.0.0",
  "scope": "continuity-legacy-governance-kernel",
  "status": "phase-1-baseline",
  "principles": [
    "clean-room reverse engineering only",
    "change explicit targets only",
    "preserve runtime behavior unless requested",
    "fail closed for structural corruption",
    "maximize fidelity at the lowest responsible cost through symbolic checks, event-driven work, and measured escalation",
    "warn before enforcing legacy cleanup",
    "keep provider strategy outside the core",
    "ignore extractable external tools"
  ],
  "required_documents": [
    "README.md",
    "PROJECT_CONTEXT.md",
    "PROJECT_DNA.md",
    "GOVERNANCE.md",
    "docs/process/REPO_AND_PYPI_RELEASE_CHECKLIST.md",
    "docs/CHANGE_CONTRACT_TEMPLATE.md",
    "docs/CONTINUITY_GOVERNANCE_KERNEL.md",
    "docs/CONEKTA_ADAPTER_CONTRACT.md"
  ],
  "required_state_files": [
    "STATE.json",
    ".continuity/STATE.json",
    ".continuity/DECISIONS_LOG.md",
    ".continuity/LIVE_HANDOFF.md",
    ".continuity/golden-baseline.json"
  ],
    "required_checks": [
    "python scripts/health_guard.py",
    "python scripts/autophagy_report.py",
    "python scripts/golden_baseline.py verify",
    "pytest",
    "python -m build",
    "twine check dist/*"
  ],
    "frozen_paths": [
    "LICENSE",
    "PROJECT_DNA.ene.md.locked",
    ".continuity/golden-baseline.json",
    "assets/",
    "banners/"
  ],
  "sensitive_paths": [
    "pyproject.toml",
    "VERSION",
    "STATE.json",
    ".continuity/",
    ".github/workflows/",
    "continuity-lite/",
    "continuity-pro/",
    "continuity-omega/"
  ],
  "change_contract_required_for": [
    "runtime behavior",
    "package metadata",
    "release workflows",
    "cryptographic state",
    "frozen paths",
    "public CLI behavior"
  ],
  "encoding_policy": {
    "target": "utf-8",
    "line_endings": "lf",
    "legacy_mojibake_markers": [
      "\u00c3\u0192",
      "\u00c3\u00a2",
      "\u00c3\u00b0",
      "\u00c3\u00af\u00c2\u00bb\u00c2\u00bf",
      "\u00e2\u20ac",
      "\u00f0\u0178",
      "\u0102",
      "\u0432\u045a",
      "\u0440\u045f"
    ],
    "phase_1_severity": "warning",
    "strict_severity": "error"
  },
  "agent_policy": {
    "allow_leaked_prompt_copying": false,
    "allow_clean_room_pattern_analysis": true,
    "require_provider_neutral_docs": true,
    "external_pricing_goes_to_external_tools": true
  },
  "optimization_policy": {
    "default_mode": "frugal_high_fidelity",
    "neural_role": "generate heuristics, patterns, creative candidates, and analysis drafts",
    "symbolic_role": "validate syntax, contracts, baselines, checks, and release gates deterministically",
    "biomimetic_rule": "prefer event-driven and changed-only work over continuous recomputation",
    "security_rule": "scan untrusted inputs, isolate risky material, and fail closed on structural corruption",
    "reverse_engineering_rule": "study public behavior and bottlenecks, then rebuild native provider-neutral controls",
    "implementation_rule": "use declarative structure for broad workflows and low-level optimization only for measured bottlenecks"
  },
  "rollback_policy": {
    "required": true,
    "destructive_cleanup_requires_human_approval": true,
    "autophagy_reports_do_not_delete": true
  }
}
