# CONTINUITY LEGACY // LOCAL CHAT BRIDGE
# Copy this file to `.env.local` on the target machine.

# Which chat backend should the dashboard use?
# Supported: openclaw | ollama | moltbot
CONTINUITY_CHAT_PROVIDER=openclaw

# OLLAMA
CONTINUITY_OLLAMA_ENABLED=true
CONTINUITY_OLLAMA_BASE_URL=http://127.0.0.1:11434
CONTINUITY_OLLAMA_MODEL=llama3.1
CONTINUITY_OLLAMA_TIMEOUT_MS=45000

# OPENCLAW
CONTINUITY_OPENCLAW_ENABLED=false
CONTINUITY_OPENCLAW_BASE_URL=http://127.0.0.1:3001
CONTINUITY_OPENCLAW_API_KEY=
CONTINUITY_OPENCLAW_TIMEOUT_MS=45000

# MOLTBOT
CONTINUITY_MOLTBOT_ENABLED=false
CONTINUITY_MOLTBOT_BASE_URL=http://127.0.0.1:3002
CONTINUITY_MOLTBOT_API_KEY=
CONTINUITY_MOLTBOT_TIMEOUT_MS=45000
